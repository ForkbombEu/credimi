{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "additionalProperties": true,
    "definitions": {
        "uriString": {
            "type": "string",
            "format": "uri"
        },
        "logo": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
                "uri": {
                    "$ref": "#/definitions/uriString"
                },
                "url": {
                    "$ref": "#/definitions/uriString"
                },
                "alt_text": {
                    "type": "string"
                }
            },
            "anyOf": [
                {
                    "required": ["uri"]
                },
                {
                    "required": ["url"]
                }
            ]
        },
        "displayItem": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
                "name": {
                    "type": "string"
                },
                "locale": {
                    "type": "string"
                },
                "description": {
                    "type": "string"
                },
                "logo": {
                    "$ref": "#/definitions/logo"
                },
                "background_color": {
                    "type": "string"
                },
                "text_color": {
                    "type": "string"
                },
                "background_image": {
                    "$ref": "#/definitions/logo"
                }
            }
        },
        "claimMetadata": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
                "path": {
                    "type": "array",
                    "items": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "integer",
                                "minimum": 0
                            },
                            {
                                "type": "null"
                            }
                        ]
                    },
                    "minItems": 1
                },
                "mandatory": {
                    "type": "boolean"
                },
                "display": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/displayItem"
                    }
                }
            }
        },
        "credentialMetadata": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
                "display": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/displayItem"
                    }
                },
                "claims": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/claimMetadata"
                    }
                }
            }
        },
        "credentialRequestEncryptionMetadata": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
                "jwks": {
                    "anyOf": [
                        {
                            "type": "object"
                        },
                        {
                            "type": "array"
                        }
                    ]
                },
                "enc_values_supported": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "minItems": 1
                },
                "zip_values_supported": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "minItems": 1
                },
                "encryption_required": {
                    "type": "boolean"
                }
            },
            "required": [
                "jwks",
                "enc_values_supported",
                "encryption_required"
            ]
        },
        "credentialResponseEncryptionMetadata": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
                "alg_values_supported": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "minItems": 1
                },
                "enc_values_supported": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "minItems": 1
                },
                "zip_values_supported": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "minItems": 1
                },
                "encryption_required": {
                    "type": "boolean"
                }
            },
            "required": [
                "alg_values_supported",
                "enc_values_supported",
                "encryption_required"
            ]
        },
        "credentialDefinition": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
                "type": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "minItems": 1
                },
                "@context": {
                    "type": "array",
                    "items": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "object"
                            }
                        ]
                    },
                    "minItems": 1
                },
                "credentialSubject": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "object",
                        "additionalProperties": true,
                        "properties": {
                            "mandatory": {
                                "type": "boolean"
                            },
                            "display": {
                                "type": "array",
                                "items": {
                                    "$ref": "#/definitions/displayItem"
                                }
                            }
                        }
                    }
                }
            }
        },
        "credentialConfiguration": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
                "format": {
                    "type": "string"
                },
                "scope": {
                    "type": "string"
                },
                "vct": {
                    "type": "string"
                },
                "doctype": {
                    "type": "string"
                },
                "claims": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/claimMetadata"
                    }
                },
                "cryptographic_binding_methods_supported": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "anyOf": [
                            {
                                "pattern": "^did:.*$"
                            },
                            {
                                "enum": ["jwk", "cose_key"]
                            }
                        ]
                    }
                },
                "credential_signing_alg_values_supported": {
                    "type": "array",
                    "items": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "integer"
                            }
                        ]
                    }
                },
                "proof_types_supported": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "object",
                        "additionalProperties": true,
                        "properties": {
                            "proof_signing_alg_values_supported": {
                                "type": "array",
                                "items": {
                                    "anyOf": [
                                        {
                                            "type": "string"
                                        },
                                        {
                                            "type": "integer"
                                        }
                                    ]
                                },
                                "minItems": 1
                            },
                            "key_attestations_required": {
                                "type": "object",
                                "additionalProperties": true,
                                "properties": {
                                    "key_storage": {
                                        "type": "array",
                                        "items": {
                                            "type": "string"
                                        }
                                    },
                                    "user_authentication": {
                                        "type": "array",
                                        "items": {
                                            "type": "string"
                                        }
                                    }
                                }
                            }
                        },
                        "required": ["proof_signing_alg_values_supported"]
                    }
                },
                "display": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/displayItem"
                    }
                },
                "credential_metadata": {
                    "$ref": "#/definitions/credentialMetadata"
                },
                "credential_definition": {
                    "$ref": "#/definitions/credentialDefinition"
                }
            },
            "required": ["format"],
            "allOf": [
                {
                    "if": {
                        "properties": {
                            "format": {
                                "const": "dc+sd-jwt"
                            }
                        },
                        "required": ["format"]
                    },
                    "then": {
                        "required": ["vct"]
                    }
                },
                {
                    "if": {
                        "properties": {
                            "format": {
                                "const": "mso_mdoc"
                            }
                        },
                        "required": ["format"]
                    },
                    "then": {
                        "required": ["doctype"]
                    }
                },
                {
                    "if": {
                        "properties": {
                            "format": {
                                "const": "jwt_vc_json"
                            }
                        },
                        "required": ["format"]
                    },
                    "then": {
                        "required": ["credential_definition"],
                        "properties": {
                            "credential_definition": {
                                "required": ["type"]
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "format": {
                                "enum": ["ldp_vc", "jwt_vc_json-ld"]
                            }
                        },
                        "required": ["format"]
                    },
                    "then": {
                        "required": ["credential_definition"],
                        "properties": {
                            "credential_definition": {
                                "required": ["@context", "type"]
                            }
                        }
                    }
                }
            ]
        }
    },
    "properties": {
        "credential_issuer": {
            "$ref": "#/definitions/uriString",
            "description": "The Credential Issuer's identifier."
        },
        "authorization_servers": {
            "type": "array",
            "items": {
                "$ref": "#/definitions/uriString"
            },
            "description": "Array of OAuth 2.0 Authorization Server identifiers."
        },
        "credential_endpoint": {
            "$ref": "#/definitions/uriString",
            "description": "URL of the Credential Issuer's Credential Endpoint."
        },
        "nonce_endpoint": {
            "$ref": "#/definitions/uriString",
            "description": "URL of the Credential Issuer's Nonce Endpoint."
        },
        "deferred_credential_endpoint": {
            "$ref": "#/definitions/uriString",
            "description": "URL of the Credential Issuer's Deferred Credential Endpoint."
        },
        "notification_endpoint": {
            "$ref": "#/definitions/uriString",
            "description": "URL of the Credential Issuer's Notification Endpoint."
        },
        "credential_request_encryption": {
            "$ref": "#/definitions/credentialRequestEncryptionMetadata"
        },
        "credential_response_encryption": {
            "$ref": "#/definitions/credentialResponseEncryptionMetadata"
        },
        "batch_credential_issuance": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
                "batch_size": {
                    "type": "integer",
                    "minimum": 2
                }
            },
            "required": ["batch_size"]
        },
        "signed_metadata": {
            "type": "string",
            "description": "JWT containing Credential Issuer metadata parameters as claims."
        },
        "display": {
            "type": "array",
            "items": {
                "$ref": "#/definitions/displayItem"
            }
        },
        "credential_configurations_supported": {
            "type": "object",
            "additionalProperties": {
                "$ref": "#/definitions/credentialConfiguration"
            }
        }
    },
    "required": [
        "credential_issuer",
        "credential_endpoint",
        "credential_configurations_supported"
    ]
}
